# LLM Configuration — works with OpenAI, Azure, Gemini, Anthropic, Ollama, or any OpenAI-compatible endpoint
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=gpt-4o

# MongoDB Atlas (Free M0 tier) — replace with your actual Atlas connection string
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/petrobot?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/petrobot?retryWrites=true&w=majority
